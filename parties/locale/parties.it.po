#: init.lua:7 src/_load.lua:30
msgid "Parties"
msgstr "Gruppi"

#: init.lua:8
msgid "Team up with your friends and create a party!"
msgstr "Fai squadra con lɜ tuoɜ amicɜ e crea un gruppo!"

#: src/_load.lua:30
msgid "Notifications"
msgstr "Notifiche"

#: src/_load.lua:32
msgid "Party invite jingle"
msgstr "Motivetto d'invito al gruppo"

#: src/_load.lua:33
msgid "Someone joins the party"
msgstr "Qualcunə entra nel gruppo"

#: src/_load.lua:34
msgid "Someone leaves the party"
msgstr "Qualcunə abbandona il gruppo"

#: src/commands.lua:6
msgid "manage parties"
msgstr "gestisce i gruppi"

#: src/commands.lua:6 src/commands.lua:18
msgid "Do `/party help` to see all the subcommands"
msgstr "Fai `/party help` per vedere tutti i sottocomandi"

#: src/commands.lua:10 src/commands.lua:30
msgid "message"
msgstr "messaggio"

#: src/commands.lua:11 src/commands.lua:30
msgid "sends a message in the party chat"
msgstr "invia un messaggio nella chat di gruppo"

#: src/commands.lua:24
msgid "COMMANDS"
msgstr "COMANDI"

#: src/commands.lua:25
msgid "disbands your party"
msgstr "sciogli il gruppo"

#: src/commands.lua:26 src/commands.lua:27 src/commands.lua:28
msgid "player"
msgstr "giocante"

#: src/commands.lua:26
msgid "invites a player to join your party. It creates one if there is none"
msgstr "invita unə giocante nel tuo gruppo. Ne crea uno se non esiste"

#: src/commands.lua:27
msgid ""
"accepts an invitation. If you've received more than one, specify `player`"
msgstr "accetta un invito. Se ne hai ricevuti più di uno, specifica `giocante`"

#: src/commands.lua:28
msgid "kicks a player from the party"
msgstr "caccia unə giocante dal gruppo"

#: src/commands.lua:29
msgid "leaves the party you're in"
msgstr "abbandona il gruppo in cui ti trovi"

#: src/commands.lua:67
msgid "[!] You must enter a message after `/p`!"
msgstr "[!] Devi scrivere un messaggio dopo `/p`!"

#: src/api.lua:26 src/api.lua:244 src/api.lua:294
msgid "[!] Only the party leader can perform this action!"
msgstr "[!] Solo lə capo gruppo può eseguire quest'azione!"

#: src/api.lua:31
msgid "[!] You can't invite yourself!"
msgstr "[!] Non ci si può invitare da solɜ!"

#: src/api.lua:36
msgid "[!] This player is not online!"
msgstr "[!] Questə giocante non è connessə!"

#: src/api.lua:41 src/api.lua:111
msgid "[!] The party has reached the maximum amount of players! (@1)"
msgstr "[!] Il gruppo ha raggiungo il tetto massimo di giocanti! (@1)"

#: src/api.lua:46
msgid "[!] This player is already in a party!"
msgstr "[!] Questə giocante è già in un gruppo!"

#: src/api.lua:51
msgid "[!] You already have a pending invite from this player!"
msgstr "[!] Hai già un invito in sospeso da parte di questə giocante!"

#: src/api.lua:56
msgid "[!] You've already invited this player!"
msgstr "[!] Hai già invitato questə giocante!"

#: src/api.lua:65
msgid "Invite to @1 successfully sent"
msgstr "Invito a @1 inviato con successo"

#: src/api.lua:66
msgid ""
"@1 has invited you to a party, would you like to join? (/party join, or /"
"party join @2 within 60 seconds)"
msgstr ""
"@1 ti ha invitato in un gruppo, vuoi unirti? (/party join, o /party join @2 "
"entro 60 secondi)"

#: src/api.lua:82
msgid "[!] You have no pending invites!"
msgstr "[!] Non hai nessun invito da accettare!"

#: src/api.lua:87
msgid "[!] You have no pending invites from this player!"
msgstr "[!] Non hai nessun invito da accettare da parte di questə giocante!"

#: src/api.lua:101
msgid ""
"[!] More players have invited you in their party: please specify the nick of "
"the one you want to join!"
msgstr ""
"[!] Più giocanti ti hanno invitato in un gruppo: specifica il nome dellə "
"giocante al quale ti vuoi unire!"

#: src/api.lua:112
msgid "@1 has tried to enter but the party is full"
msgstr "@1 ha provato ad entrare ma il gruppo è al completo"

#: src/api.lua:117
msgid "[!] The party leader has disconnected!"
msgstr "[!] Lə capo gruppo si è disconnessə!"

#: src/api.lua:126
msgid ""
"@1 has tried to enter but an external condition has prevented them from "
"doing it"
msgstr "@1 ha provato ad entrare ma una condizione esterna gliel'ha impedito"

#: src/api.lua:143 src/api.lua:158
msgid "@1 has joined another party"
msgstr "@1 si è unitə a un altro gruppo"

#: src/api.lua:154
msgid "@1 has joined the party"
msgstr "@1 si è unitə al gruppo"

#: src/api.lua:168
msgid "You've joined @1's party"
msgstr "Ti sei unitə al gruppo di @1"

#: src/api.lua:187 src/api.lua:239 src/api.lua:289 src/api.lua:350
msgid "[!] You must enter a party first!"
msgstr "[!] Devi prima entrare in un gruppo!"

#: src/api.lua:211
msgid "You've left the party"
msgstr "Sei uscitə dal gruppo"

#: src/api.lua:217 src/api.lua:226
msgid "@1 has left the party"
msgstr "@1 è uscitə dal gruppo"

#: src/api.lua:249
msgid "[!] There is no player called @1 in your party!"
msgstr "[!] Non c'è nessunə giocante nel tuo gruppo chiamatə @1!"

#: src/api.lua:254
msgid "[!] You can't kick yourself!"
msgstr "[!] Non puoi cacciare te stessə!"

#: src/api.lua:276
msgid "@1 has been kicked from the party"
msgstr "@1 è statə cacciatə dal gruppo"

#: src/api.lua:277
msgid "@1 has kicked you from the party"
msgstr "@1 ti ha cacciatə dal gruppo"

#: src/api.lua:302
msgid "The party has been disbanded"
msgstr "Il gruppo è stato sciolto"

#: src/api.lua:379
msgid "@1 is the new party leader"
msgstr "@1 è lə nuovə capo gruppo"

#: src/api.lua:447
msgid "Party"
msgstr "Gruppo"

#: src/api.lua:458
msgid "No answer from @1..."
msgstr "Nessuna risposta da @1..."
