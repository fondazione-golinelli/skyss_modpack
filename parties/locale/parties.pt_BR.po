#: init.lua:7 src/_load.lua:30
msgid "Parties"
msgstr ""

#: init.lua:8
msgid "Team up with your friends and create a party!"
msgstr "Junte-se ao seus amigos e crie uma party!"

#: src/_load.lua:30
msgid "Notifications"
msgstr "Notificações"

#: src/_load.lua:32
msgid "Party invite jingle"
msgstr ""

#: src/_load.lua:33
msgid "Someone joins the party"
msgstr "Alguém entrou na party"

#: src/_load.lua:34
msgid "Someone leaves the party"
msgstr "Alguém sai da party"

#: src/commands.lua:6
msgid "manage parties"
msgstr "gerencia parties"

#: src/commands.lua:6 src/commands.lua:18
msgid "Do `/party help` to see all the subcommands"
msgstr "Use `/party help` para ver todos os subcomandos"

#: src/commands.lua:10 src/commands.lua:30
msgid "message"
msgstr "mensagem"

#: src/commands.lua:11 src/commands.lua:30
msgid "sends a message in the party chat"
msgstr "envia uma mensagem na chat da party"

#: src/commands.lua:24
msgid "COMMANDS"
msgstr "COMANDOS"

#: src/commands.lua:25
msgid "disbands your party"
msgstr "desfaz sua party"

#: src/commands.lua:26 src/commands.lua:27 src/commands.lua:28
msgid "player"
msgstr "jogador"

#: src/commands.lua:26
msgid "invites a player to join your party. It creates one if there is none"
msgstr ""
"convida um jogador a entrar na sua party. Uma party é criada se não tiver "
"nenhuma"

#: src/commands.lua:27
msgid ""
"accepts an invitation. If you've received more than one, specify `player`"
msgstr ""
"aceita um convite. Se você recebeu mais do que um, especifique `player`"

#: src/commands.lua:28
msgid "kicks a player from the party"
msgstr "expulsa o jogador de uma party"

#: src/commands.lua:29
msgid "leaves the party you're in"
msgstr "sai da party que você está"

#: src/commands.lua:67
msgid "[!] You must enter a message after `/p`!"
msgstr "[!] Você precisa colocar uma mensagem depois de `/p`!"

#: src/api.lua:26 src/api.lua:244 src/api.lua:294
msgid "[!] Only the party leader can perform this action!"
msgstr "[!] Somente o líder da party pode fazer essa ação!"

#: src/api.lua:31
msgid "[!] You can't invite yourself!"
msgstr "[!] Você não pode convidar você mesmo!"

#: src/api.lua:36
msgid "[!] This player is not online!"
msgstr "[!] Esse jogador não está online!"

#: src/api.lua:41 src/api.lua:111
msgid "[!] The party has reached the maximum amount of players! (@1)"
msgstr "[!] A party chegou ao limite máximo de jogadores! (@1)"

#: src/api.lua:46
msgid "[!] This player is already in a party!"
msgstr "[!] Esse jogador já está na party!"

#: src/api.lua:51
msgid "[!] You already have a pending invite from this player!"
msgstr "[!] Você já tem um convite pendente desse jogador!"

#: src/api.lua:56
msgid "[!] You've already invited this player!"
msgstr "[!] Você já convidou esse jogador!"

#: src/api.lua:65
msgid "Invite to @1 successfully sent"
msgstr "Convite para @1 enviado com sucesso"

#: src/api.lua:66
msgid ""
"@1 has invited you to a party, would you like to join? (/party join, or /"
"party join @2 within 60 seconds)"
msgstr ""
"@1 te convidou para uma party, você gostaria de entrar? (/party join, ou /"
"party join @2 dentro de 60 segundos)"

#: src/api.lua:82
msgid "[!] You have no pending invites!"
msgstr "[!] Você não têm nenhum convite pendente!"

#: src/api.lua:87
msgid "[!] You have no pending invites from this player!"
msgstr "[!] Você não têm nenhum convite pendente desse jogador!"

#: src/api.lua:101
msgid ""
"[!] More players have invited you in their party: please specify the nick of "
"the one you want to join!"
msgstr ""
"[!] Mais jogadores te convidaram para a party deles: por favor especifique o "
"nick do jogador que você gostaria de se juntar!"

#: src/api.lua:112
msgid "@1 has tried to enter but the party is full"
msgstr "@1 tentou entrar mas a party está cheia"

#: src/api.lua:117
msgid "[!] The party leader has disconnected!"
msgstr "[!] O líder da party se disconectou!"

#: src/api.lua:126
msgid ""
"@1 has tried to enter but an external condition has prevented them from "
"doing it"
msgstr ""
"@1 tentou entrar mas uma condição externa preveniu ele(a) de fazer isso"

#: src/api.lua:143 src/api.lua:158
msgid "@1 has joined another party"
msgstr "@1 entrou na outra party"

#: src/api.lua:154
msgid "@1 has joined the party"
msgstr "@1 entrou na party"

#: src/api.lua:168
msgid "You've joined @1's party"
msgstr "Você entrou na party de @1"

#: src/api.lua:187 src/api.lua:239 src/api.lua:289 src/api.lua:350
msgid "[!] You must enter a party first!"
msgstr "[!] Primeiro você precisa entrar em uma party!"

#: src/api.lua:211
msgid "You've left the party"
msgstr "Você saiu da party"

#: src/api.lua:217 src/api.lua:226
msgid "@1 has left the party"
msgstr "@1 saiu da party"

#: src/api.lua:249
msgid "[!] There is no player called @1 in your party!"
msgstr "[!] Não tem nenhum jogador chamado @1 em sua party!"

#: src/api.lua:254
msgid "[!] You can't kick yourself!"
msgstr "[!] Você não pode se expulsar!"

#: src/api.lua:276
msgid "@1 has been kicked from the party"
msgstr "@1 foi expulso da party"

#: src/api.lua:277
msgid "@1 has kicked you from the party"
msgstr "@1 te expulsou da party"

#: src/api.lua:302
msgid "The party has been disbanded"
msgstr "A party foi desfeita"

#: src/api.lua:379
msgid "@1 is the new party leader"
msgstr "@1 é o novo líder da party"

#: src/api.lua:447
msgid "Party"
msgstr ""

#: src/api.lua:458
msgid "No answer from @1..."
msgstr "Nenhuma resposta de @1..."
