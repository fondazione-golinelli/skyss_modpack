#: init.lua:7 src/items.lua:7
msgid "Magic Compass"
msgstr "Magischer Kompass"

#: init.lua:8
msgid "Item to teleport into server-side defined locations"
msgstr ""
"Gegenstand, mit dem man zu vom Server definierten Orten teleportieren kann"

#: src/GUI/gui_compass.lua:138
msgid "[!] You haven't got the requirements to teleport into this area!"
msgstr ""
"[!] Du hast nicht die Voraussetzungen dafür, um sich in dieses Gebiet zu "
"teleportieren!"

#: src/GUI/gui_compass.lua:145
msgid ""
"[!] You can't reteleport to this location so quickly! (seconds remaining: @1)"
msgstr ""
"[!] Du kannst dich dorthin nicht so schnell erneut hin teleportieren! "
"(Verbleibende Sekunden: @1)"

#: src/GUI/gui_compass.lua:152
msgid "[!] Can't teleport whilst moving!"
msgstr "[!] Eine Teleportation ist nicht möglich, während man sich bewegt!"

#: src/_load.lua:76
msgid "Teleport beeps"
msgstr "Teleportpieps"

#: src/_load.lua:77
msgid "Action forbidden"
msgstr "Aktion verboten"
