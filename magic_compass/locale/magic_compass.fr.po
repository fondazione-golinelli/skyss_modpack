#: init.lua:7 src/items.lua:7
msgid "Magic Compass"
msgstr "Boussole magique"

#: init.lua:8
msgid "Item to teleport into server-side defined locations"
msgstr ""
"Objet permettant de se téléporter dans des lieux définis par le serveur"

#: src/GUI/gui_compass.lua:138
msgid "[!] You haven't got the requirements to teleport into this area!"
msgstr ""
"[!] Tu ne remplis pas les conditions requises pour te téléporter dans cette "
"arène !"

#: src/GUI/gui_compass.lua:145
msgid ""
"[!] You can't reteleport to this location so quickly! (seconds remaining: @1)"
msgstr ""
"[!] Vous ne pouvez pas vous retéléporter à cet endroit aussi rapidement ! "
"(secondes restantes : @1)"

#: src/GUI/gui_compass.lua:152
msgid "[!] Can't teleport whilst moving!"
msgstr "[!] Impossible de se téléporter en se déplaçant !"

#: src/_load.lua:76
msgid "Teleport beeps"
msgstr "Bips de téléportation"

#: src/_load.lua:77
msgid "Action forbidden"
msgstr "Action interdite"
